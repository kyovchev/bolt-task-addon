# Optimize for size/speed balance
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# Use a custom partition table file
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# Bump default flash size to 8MB
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="8MB"

# FreeRTOS Task Runtime Stats (Fixed missing CONFIG_ prefixes)
CONFIG_FREERTOS_USE_TRACE_FACILITY=y
CONFIG_FREERTOS_USE_STATS_FORMATTING_FUNCTIONS=y
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y
CONFIG_FREERTOS_RUN_TIME_COUNTER_TYPE_U32=y

# Increase Main Task (app_main) Stack Size to 16KB (Fixed value to 16384)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384

# WebSocket server support (Fixed missing CONFIG_ prefix)
CONFIG_HTTPD_WS_SUPPORT=y
